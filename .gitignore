# macOS Finder metadata — auto-generated, no value in source control
.DS_Store
._*

# Personal art-spec notes — kept locally, never deployed
Assets_Specs/

# Raw art source files (huge .png / .ai / .aep / .psd files) — only
# the web-optimized versions in assets/scenery/ ship to the live site
Animations/
*.aep
*.psd
*.ai
*.c4d
# Adobe Media Encoder output folders — auto-named *.aep_AME, contain raw
# renders we re-encode into assets/ before committing
*.aep_AME/

# Claude Code local config (preview server, etc.) — machine-specific
.claude/

# Common editor metadata — ignored just in case
.vscode/
.idea/
*.swp
